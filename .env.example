# Локально: скопируй в .env. Подними БД: npm run db:up (docker compose), затем npm run db:push.
# Railway: DATABASE_URL = Reference на сервис Postgres (см. railway.toml, railway.env.example).
# Пароль с символом & в Variables указывай в кавычках.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus"
APP_URL="http://localhost:3000"

ADMIN_USERNAME="noway"
# свой пароль; символ & обязательно в кавычках: "....&"
ADMIN_PASSWORD="your-secure-password"

# Случайная длинная строка для продакшена (можно два GUID подряд)
SESSION_COOKIE_SECRET="change-me-to-random-string"
