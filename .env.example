# Локально: скопируй в .env и при необходимости поправь.
# Railway: те же ключи в Variables (пароль в кавычках из‑за &).

DATABASE_URL="file:./dev.db"
APP_URL="http://localhost:3000"

ADMIN_USERNAME="noway"
# свой пароль; символ & обязательно в кавычках: "....&"
ADMIN_PASSWORD="your-secure-password"

# Случайная длинная строка для продакшена (можно два GUID подряд)
SESSION_COOKIE_SECRET="change-me-to-random-string"
