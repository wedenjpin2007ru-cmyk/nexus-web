# Шаблон для Railway → Variables (веб-сервис, не Postgres).
# Скопируй строку DATABASE_URL в значение переменной или используй UI «Reference».
#
# «Postgres» замени на точное имя сервиса базы в твоём проекте (как в сайдбаре Railway).

DATABASE_URL=${{ Postgres.DATABASE_URL }}

# Если в логах ошибки SSL / certificate при подключении к Postgres:
# PGSSL_NO_VERIFY=1
