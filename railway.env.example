# Шаблон для Railway → Variables (веб-сервис, не Postgres).
# Скопируй строку DATABASE_URL в значение переменной или используй UI «Reference».
#
# «Postgres» замени на точное имя сервиса базы в твоём проекте (как в сайдбаре Railway).

DATABASE_URL=${{ Postgres.DATABASE_URL }}

# Публичный URL сайта (метаданные Open Graph + можно использовать в .env для сборки клиента)
# NEXT_PUBLIC_SITE_URL=https://твой-сервис.up.railway.app

# Если в логах ошибки SSL / certificate при подключении к Postgres:
# PGSSL_NO_VERIFY=1
#
# Стабильность пула (меньше «вечных» запросов → 502 у Railway):
# PG_POOL_MAX=5
# PG_CONNECTION_TIMEOUT_MS=20000
#
# Health: по умолчанию /api/health пингует БД. Если деплой падает на health, временно:
# HEALTH_SKIP_DB=1
# или увеличь HEALTH_DB_TIMEOUT_MS=15000
#
# Бесплатный/уснувший инстанс Railway: первый запрос после сна может быть долгим —
# для продакшена держи сервис «awake» (платный план / минимум 1 реплика).
